# Copia este archivo a .env y pega tu API Key de Google AI Studio (Gemini)
# https://aistudio.google.com/

GEMINI_API_KEY=your_api_key_here
# Opcional: cambiar el modelo sin editar JS.
# Si no existe o no soporta generateContent, el chatbot probará fallbacks automáticamente.
GEMINI_MODEL=gemini-2.0-flash
